{
  "expo": {
    "name": "BaldLeer",
    "slug": "baldleer-smart-refill",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "baldleer",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
